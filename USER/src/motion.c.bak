                                    {
                                        //SET_AVG

//                                        SET_500m_500
//                                        SET_500m_m
                                        //SET_TIME1_S31
                                        ImageTime1(intervalRecord[disp_steps - 2].HIS_timeFor500m / 60, intervalRecord[disp_steps - 2].HIS_timeFor500m % 60);
                                        SET_TIME1_COL
