uint16_t key_connect_longPress, key_enter_longPress, key_reset_longPress;

eulong split_total;
euint update_cnt;
extern float dis_s_total, c_total;
uint16_t clear_cnt;
uint8_t beep_on_prev,flag_mile_prev,race_on_prev,time2sleep_prev;

//uint8_t select_step1,select_step2,dis_drag;
void UserConsumerKeys(void)
{
    uint8_t i;

    /*---------------------------------------------------*
     |  Process key function associate with the key press
     *---------------------------------------------------*/
    #if 0

    if(key_id == KEY_CONNECT && flag_module_2_mobile == 0)
    {
        //key_id_done = 1;
        if(key_connect_longPress >= 600)
        {
            beep(BEEP_KEY);
            key_connect_longPress = 0;
            atCMD_cnt = 0;
            atCMD_cnt_last = 0xff;

            if(flag_ANTorBLE_heart == 0 || flag_ANTorBLE_heart == 2) flag_ANTorBLE_heart = 1;
            else flag_ANTorBLE_heart = 2;
        }
        else key_connect_longPress++;
    }
    else key_connect_longPress = 0;

    #endif

    if(key_id == KEY_VERSION && userstate == USER_STATE_READY
            && interval_list == 0 && interval_Dist == 0 && interval_Cal == 0 && interval_Time == 0 && disp_history == 0 && disp_setting == 0
            && target_distance == 0 && target_cal == 0 && target_time == 0 && target_age == 0 && target_list == 0)
    {
        if(key_enter_longPress >= 600)
        {
            beep(BEEP_KEY);
            key_enter_longPress = 0;
            disp_version = 400;
        }
        else key_enter_longPress++;
    }
    else key_enter_longPress = 0;

    if(key_id == KEY_RESET && userstate == USER_STATE_READY
            && interval_list == 0 && interval_Dist == 0 && interval_Cal == 0 && interval_Time == 0 && disp_history == 0 && disp_setting == 0
            && target_distance == 0 && target_cal == 0 && target_time == 0 && target_age == 0 && target_list == 0)
    {
        if(key_reset_longPress >= 600)
        {
            waiting_cnt = DISPLAY_ALL_ON_DELAY - 1; //all on for 1 second
            waiting = 1;
            beep(BEEP_KEY);
            key_reset_longPress = 0;

            flag_mile = 0;
            race_on = 0;
            time2sleep = 1;//5;
            target_age = 0;
            eeprom_clear(EEPROM_ADDR_INI);
            eeprom_write_long(EEPROM_ADDR_BEEP, beep_on);

            for(i = 0; i < 20; i++)
            {
                history[i].HIS_timeFor500m = 0;
                history[i].HIS_watts = 0;
                history[i].HIS_spm = 0;
                history[i].HIS_avg_hr = 0;
                history[i].HIS_DistFor30min = 0;
                history[i].HIS_distance = 0;
                history[i].HIS_calories = 0;
                history[i].HIS_time = 0;
            }

            historyRecordCnt = 0;
            eeprom_clear(EEPROM_ADDR_HISTORY_INI);

            for(i = 0; i < 99; i++)
            {
                intervalDist_workDist[i] = 0;
                intervalDist_resetTime[i] = 0;
//                intervalCal_workCal[i] = 0;
//                intervalCal_resetTime[i] = 0;
//                intervalTime_workTime[i] = 0;
//                intervalTime_resetTime[i] = 0;
            }
        }
        else key_reset_longPress++;
    }
    else key_reset_longPress = 0;


    if (key_id != KEY_NONE && key_id_done == 0 && waiting == 0)
    {
        clear_cnt = 0;
        key_id_done = 1;

        if(userstate != USER_STATE_TICK) state_sec = 0;

        bg_light = 10; //8;

        if(userstate == USER_STATE_SLEEP)
        {
            //waiting_cnt = DISPLAY_ALL_ON_DELAY; //all on for 1 second
            //waiting = 1;
            clearPara();
            beep(BEEP_KEY);
            GOTO_STATE(USER_STATE_READY);
            return;
        }
        else if(userstate == USER_STATE_PERSTOP && key_id != KEY_UP && key_id != KEY_DOWN && key_id != KEY_START)
        {
            flag_beep6 = 0;
            interval_set = 0;
            interval_list = 0;
            interval_cnt = 0;
            interval_Dist = 0;
            interval_Cal = 0;
            interval_Time = 0;

            target_distance = 0;
            target_cal = 0;
            target_time = 0;
            target_age = 0;
            target_list = 0;
            user_distance_target = 0;

            //runTOready = 0;
            resistance_pause = 0;
            user_time_minute = 0;
            user_time_second = 0;
            user_distance = 0;
            user_calories = 0;
            dis_s_total = 0;
            c_total = 0;
            Drag_coeff = 0;
            split = 0;
            pcount = 0;
            watts = 0;
            timeFor500m = 0;
            DistFor30min = 0;
            caloriesPerHour = 0;
            avg_hr = 0;
            max_hr = 0;

            split_total = 0;
            update_cnt = 0;

            GOTO_STATE(USER_STATE_READY);
        }

        switch (key_id)
        {
            case KEY_START:
                if(disp_history > 0 || disp_setting > 0) break;

                if(userstate == USER_STATE_READY || userstate == USER_STATE_PAUSE || userstate == USER_STATE_PERSTOP)
                {
                    disp_steps = 0;
                    beep(BEEP_KEY);

                    if(userstate == USER_STATE_PERSTOP)
                    {
                        if(race_on == 0)
                        {
                            interval_set = 0;
                            interval_list = 0;
                            interval_cnt = 0;
                            interval_Dist = 0;
                            interval_Cal = 0;
                            interval_Time = 0;
                        }
                        else
                        {
													#if 0
                            if(interval_list > 0)
                            {
                                interval_cnt = 0;
                                interval_sec = interval_workTime;
                                interval_recordCal = 0;
                                interval_recordDist = 0;
                                interval_recordTime = 0;

                                if(interval_list == 8 || interval_list == 9)
                                {
                                    //interval_recordCal=0;
                                    interval_cal = intervalCal_workCal[0];
                                    interval_sec = 0;
                                }
                                else if(interval_list == 10 || interval_list == 11 || interval_list == 12 || interval_list == 14 || interval_list == 13 || interval_list == 17)
                                {
                                    //interval_recordDist=0;
                                    interval_dist = intervalDist_workDist[0];
                                    interval_sec = 0;
                                }
                            }
                            else 
															#endif
															if(interval_Dist == 1)
                            {
                                interval_cnt = 0;
                                interval_recordDist = 0;
                                interval_recordCal = 0;
                                interval_recordTime = 0;
                                interval_dist = intervalDist_workDist[0];
                                interval_sec = 0; //intervalDist_resetTime[0];
                                interval_set = 0;
                            }
                            else if(interval_Cal == 1)
                            {
                                interval_cnt = 0;
                                interval_recordDist = 0;
                                interval_recordCal = 0;
                                interval_recordTime = 0;
                                //interval_cal = intervalCal_workCal[0];
                                interval_cal = intervalCal_workCal_set;
                                interval_sec = 0; //intervalCal_resetTime[0];
                                interval_set = 0;
                            }
                            else if(interval_Time == 1)
                            {
                                interval_cnt = 0;
								//interval_time = intervalTime_workTime[0];
                                interval_time = intervalTime_workTime_set;
                                interval_sec = 0;//intervalTime_workTime[0];
                                interval_set = 0;
                            }
                        }

                        //runTOready = 0;
                        resistance_pause = 0;
                        user_time_minute = 0;
                        user_time_second = 0;
                        user_distance = 0;
                        user_calories = 0;
                        dis_s_total = 0;
                        c_total = 0;
                        Drag_coeff = 0;
                        split = 0;
                        pcount = 0;
                        watts = 0;
                        timeFor500m = 0;
                        DistFor30min = 0;
                        caloriesPerHour = 0;
                        avg_hr = 0;
                        max_hr = 0;

                        split_total = 0;
                        update_cnt = 0;
                    }

                    flag_pauseKey = 0;
                    
                    if(userstate == USER_STATE_PAUSE) GOTO_STATE(USER_STATE_RUN);
                    else GOTO_STATE(USER_STATE_TICK);
                }

                break;

            case KEY_STOP:
                disp_version = 0;

