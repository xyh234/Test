								else disp_avg=0;
							}
							#endif
										

                if(batVolt_measured > 3865) SET_Battery_5//5.8v
                if(batVolt_measured > 3600) SET_Battery_4//5.4v
                    if(batVolt_measured > 3395) SET_Battery_3//5.1v
                        if(batVolt_measured > 3125) SET_Battery_2//4.7v
                            if(batVolt_measured > 3045) SET_Battery_1//4.4v
