                                        if(flag_mile == 1)
                                        {
                                            tmp32 = intervalRecord[disp_steps - 2].HIS_distance * 0.00621;
                                            ImageDist2(tmp32);
                                            //SET_DIST_I;
                                        }
                                        else if(flag_mile == 2)
                                        {
                                            tmp32 = intervalRecord[disp_steps - 2].HIS_distance / 100;
                                            ImageDist2(tmp32);
                                            SET_DIST_K;
                                        }
                                        else
                                        {
                                            if(intervalRecord[disp_steps - 2].HIS_distance > 999999) //>=10000)
                                            {
                                                tmp32 = intervalRecord[disp_steps - 2].HIS_distance / 100;
                                                ImageDist2(tmp32);
                                                SET_DIST_K;
                                            }
                                            else ImageDist(intervalRecord[disp_steps - 2].HIS_distance);
                                        }

                                        //SET_DISTANCE_S19;
                                        SET_DISTANCE;
                                        SET_DIST_M;

                                        if(wattsORcal==1)
																				{
																					SET_CAL
																					//SET_CAL_S18
																					//SET_CAL_pHR
																					ImageCal(intervalRecord[disp_steps - 2].HIS_calories);
																				}

                                        if(intervalRecord[disp_steps - 2].HIS_time < 3600) ImageTime(intervalRecord[disp_steps - 2].HIS_time / 60, intervalRecord[disp_steps - 2].HIS_time % 60);
                                        else
                                        {
                                            ImageTime_1(intervalRecord[disp_steps - 2].HIS_time / 3600, (intervalRecord[disp_steps - 2].HIS_time % 3600) / 60, intervalRecord[disp_steps - 2].HIS_time % 60);
                                            SET_TIME_COL_M
                                        }
																				SET_TIME_COL_M

                                        //SET_TIME_COL_H;
                                        SET_TIME;

                                        SET_INTERVALS
																				SET_CYCLE
                                        ImageINTERVALS1(disp_steps - 1);
																				SET_INTERVALS_LINE1
                                        //SET_INTERVALS_S43

                                        if(interval_list == 13 || interval_list == 6)
                                        {
                                            ImageINTERVALS2(interval_cnt / 2); //(disp_steps-1);
																					  SET_INTERVALS_LINE2
                                        }
                                        else
                                        {
                                            ImageINTERVALS2(interval_cycle);
																					  SET_INTERVALS_LINE2
                                        }

                                    }
                                    else
                                    {
//                                        if(disp_avg == 1) SET_AVG
//                                            else if(disp_max == 1) SET_MAX

//                                                SET_500m_500
//                                                SET_500m_m

                                                //SET_TIME1_S31
                                                if(disp_avg == 1) 
																								{
																									ImageTime1(timeFor500m_avg / 60, timeFor500m_avg % 60);
																									SET_AVE_TIME
																								}
                                                else if(disp_max == 1) ImageTime1(timeFor500m_max / 60, timeFor500m_max % 60);
                                                else 
																								{
																									ImageTime1(timeFor500m / 60, timeFor500m % 60);
																									SET_500m
																								}

                                        SET_TIME1_COL
																			  


																			  if(wattsORcal==0)
																				{
																					CLR_CAL
																					SET_WATTS
																					if(disp_avg == 1) 
																					{
																						ImageWatts(watts_avg);
																						SET_AVE_CAL_WATT
																					}
																					else if(disp_max == 1) ImageWatts(watts_max);
																					else ImageWatts(watts);
																				}
																				else if(wattsORcal==1)
																				{
																					  CLR_WATTS
                                            SET_CAL
                                            //SET_CAL_S18
                                            if(disp_avg == 1)
                                            {
                                                //SET_CAL_pHR
                                                ImageCal(caloriesPerHour_avg);
																							  SET_AVE_CAL_WATT
                                            }
                                            else if(disp_max == 1)
                                            {
                                                //SET_CAL_pHR
                                                ImageCal(caloriesPerHour_max);
                                            }
                                            else ImageCal(user_calories);
																				 }
																				

                                        if(user_hr > 0)
                                        {
                                            SET_Heart

                                            if(disp_avg == 1)
                                            {
                                                //SET_AVG
                                                ImageHeart(avg_hr);
                                            }
                                            else if(disp_max == 1)
                                            {
                                                //SET_MAX
                                                ImageHeart(max_hr);
                                            }
                                            else ImageHeart(user_hr);
                                        }


                                        if(disp_avg == 1) 
																				{
																					ImageSPM(split_avg);
																					ImageSPM_LEVEL(split_avg);
																				}
                                        else if(disp_max == 1) 
																				{
																					ImageSPM(split_max);
																					ImageSPM_LEVEL(split_max);
																				}
                                        else 
																				{
																					ImageSPM(split);
																					ImageSPM_LEVEL(split);
																				}

                                        //SET_SPM_S12;
                                        SET_SPM;


//                                        SET_mP30min_M
//                                        SET_mP30min_30
//                                        SET_mP30min_min
                                        //SET_mP30min_S35
																				SET_30MIN
                                        ImageMSG(DistFor30min);


                                        if(flag_mile == 1)
                                        {
                                            tmp32 = user_distance * 0.00621;
                                            ImageDist2(tmp32);
                                        }
                                        else if(flag_mile == 2)
                                        {
                                            tmp32 = user_distance / 100;
                                            ImageDist2(tmp32);
                                            SET_DIST_K;
                                        }
                                        else
                                        {
                                            if(user_distance > 999999) //>=10000)
                                            {
                                                tmp32 = user_distance / 100;
                                                ImageDist2(tmp32);
                                                SET_DIST_K;
                                            }
                                            else ImageDist(user_distance);
                                        }

                                        //SET_DISTANCE_S19;
                                        SET_DISTANCE;
                                        SET_DIST_M;

//                                        if(flag_mile == 1) SET_DIST_I

																				
                                        //if(user_time_minute < 60) 
																					ImageTime(user_time_minute, user_time_second);
																				#if 0
                                        else
                                        {
                                            ImageTime_1(user_time_minute / 60, user_time_minute % 60, user_time_second);
                                            SET_TIME_COL_M
                                        }
																				#endif
																				SET_TIME_COL_M

                                        //SET_TIME_COL_H;
                                        SET_TIME;
                                    }
            }
        }
        else disp_flash = 0;

        #endif
    }
    else
    {
        flash_icon = 0;
        split_cnt2 = 0;
        bg_light = 0;
        disp_flash = 0;

        ImageAll(0xff);

        if(waiting_cnt == DISPLAY_ALL_ON_DELAY)
        {
            beep(BEEP_INT);
        }

        if (waiting_cnt > 0) //set with the waiting variable
        {
            waiting_cnt--;
        }
        else
        {
            waiting = 0;
        }
    }

//    if(flag_beep6==0||flag_beep6==1||flag_beep6>3) buffToImage();
#endif			
    buffToImage();
    DisplayDriverProcess();
}


uint8_t UserKeySlew(void)
{
    //this key can be processed in slew
    key_slew_cnt++;         //in 20ms

    //process when first time presure and after 0.8s, 0.3s, 0.2s
    if (key_slew_cnt == KEY_SLEW_RATE0 || key_slew_cnt == KEY_SLEW_RATE1
            || key_slew_cnt == KEY_SLEW_RATE2 || key_slew_cnt == KEY_SLEW_RATE3
            || key_slew_cnt == KEY_SLEW_RATE4 || key_slew_cnt == KEY_SLEW_RATE5)
    {
        //go to key process
    }
    else return(0);

    if (key_slew_cnt >= KEY_SLEW_RATE5)key_slew_cnt = KEY_SLEW_RATE4;

    return(1);
}
