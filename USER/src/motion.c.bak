                            if(interval_cnt % 2 == 1)
                            {
                                //if(disp_flash < 400) //(state_tick<100)
                                    SET_RESET
                                    ImageListTime(interval_sec);
                            }
                            else
                            {
                                //if(disp_flash < 400) //(state_tick<100)
