//                SET_Divider_S24
//                SET_Divider_S36
//                SET_Divider_S39

							#if 0
                disp_avg = 0;
                disp_max = 0;

                if(disp_steps == 1) disp_max = 1;
                else disp_avg = 1;
							#endif
							
							if(select_step2>0)
