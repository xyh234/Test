										if(interval_Dist==1 || interval_Cal==1 || interval_Time==1)	//ÔÝÍŁĘ±INTERVALÄŁĘ˝ŇŞĎÔĘľłöČ¦ĘýşÍą¤×÷Ę±ĽäşÍĐÝĎ˘Ę±Ľä
										{
											#if 0
